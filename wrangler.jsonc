{
  // Trợ lý AI nội bộ Daisan Group.
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "daisan-internal-ai",
  // Tài khoản chứa Worker (Nhamphongdaijsc@gmail.com's Account). Ghi cố định để
  // wrangler không bị nhập nhằng khi token có quyền trên nhiều account.
  "account_id": "4916931057954a4b6187316d83b4a5f2",
  "main": "src/index.ts",
  // Tắt URL *.workers.dev — chỉ cho truy cập qua troly.daisan.ai (đã bọc Cloudflare Access).
  "workers_dev": false,
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  // Workers AI — dùng cho binding AutoRAG (env.AI.autorag(...)).
  "ai": {
    "binding": "AI"
  },

  // Biến cấu hình (không phải secret). Secret đặt qua `wrangler secret put`.
  "vars": {
    // Tên AutoRAG instance đã tạo trong dashboard (AI > AI Search).
    "AUTORAG_NAME": "daisan-internal-ai",
    // AI Gateway dùng chung của Daisan để route Claude (billing/analytics gộp).
    "CF_ACCOUNT_ID": "4916931057954a4b6187316d83b4a5f2",
    "AI_GATEWAY_NAME": "daisan-gw",
    // Model Claude mặc định (điều chỉnh theo model bạn được cấp).
    "DEFAULT_MODEL": "claude-sonnet-4-6",
    // Số đoạn tài liệu lấy về mỗi truy vấn.
    "RAG_TOP_K": "8",
    // Ngưỡng điểm tương đồng tối thiểu (0-1) để giữ đoạn tài liệu.
    // 0.2: ưu tiên recall cho tiếng Việt (bge-m3 điểm thường thấp). Tăng dần nếu nhiễu.
    "RAG_SCORE_THRESHOLD": "0.2",

    // --- Odoo (CHỈ ĐỌC) — xem src/odoo.ts ---
    // URL/DB/UID là cấu hình thường; API key + login đặt bằng `wrangler secret put`.
    "ODOO_URL": "https://dserp.odoo.com",
    "ODOO_DB": "daisan-vn-daisanerp-main-22763695",
    // Đăng nhập bằng login -> Odoo trả về ĐÚNG uid của chủ nhân API key.
    // (Ưu tiên hơn ODOO_UID để tránh "Access Denied" do uid để cứng bị sai.)
    "ODOO_LOGIN": "nhamphongdaijsc@gmail.com",
    // Giữ làm fallback; chỉ dùng khi không có ODOO_LOGIN.
    "ODOO_UID": "6",

    // Email được xem trang admin/lịch sử đăng nhập (phân tách bằng dấu phẩy).
    // Thêm email quản lý khác vào đây nếu muốn cho họ xem. Để trống = mọi người xem được.
    "ADMIN_EMAILS": "nhamphongdaijsc@gmail.com",

    // --- Google Drive sync (CHỈ ĐỌC) — xem src/gdrive.ts ---
    // ID thư mục Drive cần đồng bộ (lấy từ URL thư mục; nhiều thì cách nhau dấu phẩy).
    // Khóa service account đặt riêng: wrangler secret put GDRIVE_SA_JSON
    "GDRIVE_FOLDER_ID": "19VjUs1ILWpbtjbKbNzROCyZwrkkespUj"
  },

  // Cron: tự động đồng bộ Google Drive mỗi ngày lúc 02:00 giờ VN (19:00 UTC).
  "triggers": { "crons": ["0 19 * * *"] },

  // Custom domain để nhân viên truy cập; sẽ bọc Cloudflare Access (chỉ email @daisan).
  "routes": [{ "pattern": "troly.daisan.ai", "custom_domain": true }],

  "observability": {
    "enabled": true
  },

  // Phase 2: lịch sử chat theo từng người (user_email lấy từ Cloudflare Access).
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "daisan-internal-ai",
      "database_id": "c6c9dedc-53dc-4153-8d4c-95b52a703e8a"
    }
  ],

  // Phase 2: trang admin upload tài liệu lên R2 (AutoRAG sẽ tự index).
  "r2_buckets": [
    { "binding": "DOCS", "bucket_name": "daisan-internal-ai-docs" }
  ]
}
